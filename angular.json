{
  "$schema": "./node_modules/@angular/cli/lib/config/schema.json",
  "cli": {
    "analytics": "4797eaf6-816f-47da-bc67-742503c17cfd"
  },
  "version": 1,
  "newProjectRoot": "projects",
  "projects": {
    "rubic": {
      "root": "",
      "sourceRoot": "src",
      "projectType": "application",
      "prefix": "app",
      "schematics": {
        "@schematics/angular:component": {
          "style": "scss",
          "changeDetection": "OnPush",
          "standalone": false,
          "skipTests": true
        }
      },
      "architect": {
        "build": {
          "builder": "@angular-devkit/build-angular:application",
          "options": {
            "aot": true,
            "webWorkerTsConfig": "tsconfig.worker.json",
            "outputPath": {
              "base": "dist/rubic",
              "browser": ""
            },
            "index": "src/index.html",
            "polyfills": ["src/polyfills.ts"],
            "tsConfig": "src/tsconfig.app.json",
            "assets": [
              "src/assets",
              "src/favicon.ico",
              "src/manifest.json",
              "src/robots.txt",
              "src/sitemap.xml",
              {
                "glob": "**/*",
                "input": "node_modules/@taiga-ui/icons/src",
                "output": "assets/taiga-ui/icons"
              },
              {
                "glob": "poseidon_hash_wasm_bg.wasm",
                "input": "node_modules/@railgun-community/poseidon-hash-wasm/pkg-esm",
                "output": "assets/railgun"
              },
              {
                "glob": "curve25519_scalarmult_wasm_bg.wasm",
                "input": "node_modules/@railgun-community/curve25519-scalarmult-wasm/pkg-esm",
                "output": "assets/railgun"
              },
              {
                "glob": "kms_lib_bg.wasm",
                "input": "node_modules/@zama-fhe/relayer-sdk/lib",
                "output": "/assets/zama"
              },
              {
                "glob": "tfhe_bg.wasm",
                "input": "node_modules/@zama-fhe/relayer-sdk/lib",
                "output": "/assets/zama"
              }
            ],
            "styles": [
              "node_modules/@taiga-ui/core/styles/taiga-ui-fonts.less",
              "node_modules/@taiga-ui/styles/taiga-ui-global.less",
              "node_modules/@taiga-ui/core/styles/taiga-ui-theme.less",
              "src/styles.scss"
            ],
            "stylePreprocessorOptions": {
              "includePaths": ["."]
            },
            "scripts": ["src/assets/analytics/live-chat.js"],
            "define": {
              "process": "globalThis.process"
            },
            "allowedCommonJsDependencies": [
              "bignumber.js",
              "decimal.js-light",
              "hash.js",
              "big.js",
              "ng-inline-svg-2/lib_commonjs/inline-svg.module",
              "stream-browserify"
            ],
            "extractLicenses": false,
            "sourceMap": {
              "scripts": true,
              "styles": false,
              "vendor": false
            },
            "optimization": false
          },
          "configurations": {
            "local": {
              "fileReplacements": [
                {
                  "replace": "src/environments/environment.ts",
                  "with": "src/environments/environment.local.ts"
                }
              ]
            },
            "dev": {
              "fileReplacements": [
                {
                  "replace": "src/environments/environment.ts",
                  "with": "src/environments/environment.dev.ts"
                }
              ]
            },
            "dev2": {
              "fileReplacements": [
                {
                  "replace": "src/environments/environment.ts",
                  "with": "src/environments/environment.dev2.ts"
                }
              ]
            },
            "dev3": {
              "fileReplacements": [
                {
                  "replace": "src/environments/environment.ts",
                  "with": "src/environments/environment.dev3.ts"
                }
              ]
            },
            "dev4": {
              "fileReplacements": [
                {
                  "replace": "src/environments/environment.ts",
                  "with": "src/environments/environment.dev4.ts"
                }
              ]
            },
            "dev5": {
              "fileReplacements": [
                {
                  "replace": "src/environments/environment.ts",
                  "with": "src/environments/environment.dev5.ts"
                }
              ]
            },
            "dev6": {
              "fileReplacements": [
                {
                  "replace": "src/environments/environment.ts",
                  "with": "src/environments/environment.dev6.ts"
                }
              ]
            },
            "prod-api": {
              "fileReplacements": [
                {
                  "replace": "src/environments/environment.ts",
                  "with": "src/environments/environment.prod-api.ts"
                }
              ]
            },
            "production": {
              "fileReplacements": [
                {
                  "replace": "src/environments/environment.ts",
                  "with": "src/environments/environment.prod.ts"
                }
              ],
              "optimization": true,
              "outputHashing": "all",
              "sourceMap": false,
              "aot": true,
              "extractLicenses": true,
              "budgets": [
                {
                  "type": "initial",
                  "maximumWarning": "6mb",
                  "maximumError": "20mb"
                },
                {
                  "type": "anyComponentStyle",
                  "maximumWarning": "6kb"
                }
              ]
            },
            "stage": {
              "fileReplacements": [
                {
                  "replace": "src/environments/environment.ts",
                  "with": "src/environments/environment.stage.ts"
                }
              ],
              "optimization": true,
              "outputHashing": "all",
              "sourceMap": false,
              "aot": true,
              "extractLicenses": true,
              "budgets": [
                {
                  "type": "initial",
                  "maximumWarning": "6mb",
                  "maximumError": "20mb"
                },
                {
                  "type": "anyComponentStyle",
                  "maximumWarning": "6kb"
                }
              ]
            }
          },
          "defaultConfiguration": ""
        },
        "serve": {
          "builder": "@angular-devkit/build-angular:dev-server",
          "options": {
            "buildTarget": "rubic:build",
            "proxyConfig": "proxy.conf.js"
          },
          "configurations": {
            "production": {
              "buildTarget": "rubic:build:production"
            },
            "local": {
              "buildTarget": "rubic:build:local"
            },
            "dev": {
              "buildTarget": "rubic:build:dev"
            },
            "dev2": {
              "buildTarget": "rubic:build:dev2"
            },
            "dev3": {
              "buildTarget": "rubic:build:dev3"
            },
            "dev4": {
              "buildTarget": "rubic:build:dev4"
            },
            "dev5": {
              "buildTarget": "rubic:build:dev5"
            },
            "dev6": {
              "buildTarget": "rubic:build:dev6"
            },
            "prod-api": {
              "buildTarget": "rubic:build:prod-api"
            },
            "stage": {
              "buildTarget": "rubic:build:stage"
            }
          }
        },
        "extract-i18n": {
          "builder": "@angular-devkit/build-angular:extract-i18n",
          "options": {
            "buildTarget": "rubic:build"
          }
        },
        "test": {
          "builder": "@angular-devkit/build-angular:karma",
          "options": {
            "codeCoverage": true,
            "main": "src/test.ts",
            "polyfills": ["src/polyfills.ts"],
            "tsConfig": "src/tsconfig.spec.json",
            "karmaConfig": "src/karma.conf.js",
            "styles": ["src/styles.scss"],
            "scripts": [],
            "assets": ["src/favicon.ico", "src/assets"],
            "webWorkerTsConfig": "tsconfig.worker.json"
          }
        },
        "lint": {
          "builder": "@angular-eslint/builder:lint",
          "options": {
            "lintFilePatterns": ["src/**/*.ts", "src/**/*.component.html"]
          }
        }
      }
    },
    "rubic-e2e": {
      "root": "e2e/",
      "projectType": "application",
      "prefix": "",
      "architect": {
        "e2e": {
          "builder": "@angular-devkit/build-angular:protractor",
          "options": {
            "protractorConfig": "e2e/protractor.conf.js",
            "devServerTarget": "rubic:serve"
          },
          "configurations": {
            "production": {
              "devServerTarget": "rubic:serve:production"
            }
          }
        }
      }
    }
  }
}
